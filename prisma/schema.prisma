// Public landing-page purchase orders awaiting admin provisioning.
// Customer submits (student name + phone required, email optional), pays
// (mock now, Moyasar-ready), then admin creates the student account and
// assigns class/program/teacher. Mirrors the TrialRequest lead-capture pattern.
model PurchaseOrder {
  id                   String             @id @default(uuid())
  // Customer-provided at checkout
  studentName          String
  phone                String
  email                String?
  packageType          PackageType
  notes                String?
  // Payment (mock now, Moyasar-ready)
  amountSar            Decimal            @db.Decimal(10, 2)
  paymentStatus        OrderPaymentStatus @default(PENDING)
  moyasarPaymentId     String?
  paidAt               DateTime?
  // Admin provisioning workflow
  status               OrderStatus        @default(NEW)
  provisionedStudentId String?
  assignedClassId      String?
  handledBy            String?
  handledAt            DateTime?
  source               String             @default("landing_checkout")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([paymentStatus])
}

// ─────────────────────── OWNER BATCH 3 ───────────────────────

// C5 — Per-admin private sticky notes / reminders shown on the admin dashboard.
// Access is gated server-side (admin-only, scoped to ownerId == session.user.id).
model StickyNote {
  id        String          @id @default(uuid())
  ownerId   String
  owner     User            @relation("StickyNoteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  body      String          @db.Text
  color     StickyNoteColor @default(YELLOW)
  done      Boolean         @default(false)
  dueAt     DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId, done, createdAt])
}

enum StickyNoteColor {
  YELLOW
  GREEN
  BLUE
  PINK
  PURPLE
}

// C7 — A video the admin uploads FOR specific users (targeted). Stored in a private
// bucket; chosen users see it on their recordings surface via short-lived signed URLs.
// Access gated server-side: an uploader admin, or a user listed in viewers.
model TargetedRecording {
  id            String                    @id @default(uuid())
  title         String
  titleAr       String?
  description   String?                   @db.Text
  descriptionAr String?                   @db.Text
  storagePath   String // path inside the private bucket
  mimeType      String
  sizeBytes     Int
  durationSec   Int?
  uploadedById  String
  uploadedBy    User                      @relation("TargetedRecordingUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  viewers       TargetedRecordingViewer[]
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@index([uploadedById, createdAt])
}

// Join: which users a TargetedRecording is shared with (+ per-user viewed tracking).
model TargetedRecordingViewer {
  id          String            @id @default(uuid())
  recordingId String
  recording   TargetedRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation("TargetedRecordingViewer", fields: [userId], references: [id], onDelete: Cascade)
  viewedAt    DateTime?
  createdAt   DateTime          @default(now())

  @@unique([recordingId, userId])
  @@index([userId, viewedAt])
}

// Password reset: a single-use, time-limited token. Only the SHA-256 hash of
// the token is stored; the raw token travels in the emailed reset link. Lookup
// is by hash, so a DB read never reveals a usable token.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─────────────────────── PUBLIC FEEDBACK SURVEY ───────────────────────
//
// A shareable, NO-AUTH testimonial/feedback form (/survey). Anyone with the
// link — typically a student or parent — rates their experience and a teacher
// (free-typed name, so it works for any teacher on or off platform) and may
// optionally leave a written testimonial, a recorded VOICE message, and/or a
// recorded VIDEO. Media lives in the private `survey-media` bucket; only the
// storage PATH is persisted here and admins fetch a short-lived signed URL.
//
// PDPL: name/contact are OPTIONAL and never required to submit. Raw IP is
// never stored — only a short SHA-256 hash (ipHash) for light abuse triage.
// `consentTestimonial` records explicit permission to use the feedback (incl.
// any recording) in Hajr marketing; submitting WITHOUT consent is allowed.
model FeedbackSurveyResponse {
  id String @id @default(uuid())

  // Who is giving feedback, and about whom.
  respondentType  SurveyRespondentType
  teacherName     String // free text — any teacher, on-platform or not
  studentName     String? // optional free text
  programOrClass  String? // optional free text

  // Short written questions.
  ratingOverall     Int // 1–5, REQUIRED
  qualityRating     Int? // 1–5 teaching quality
  commsRating       Int? // 1–5 communication
  improved          SurveyImproved? // did the student improve
  recommendRating   Int? // 1–5 would recommend
  likedMost         String? @db.Text
  improveSuggestion String? @db.Text

  // Rich feedback (all optional). Media URLs hold the private storage PATH.
  textTestimonial String?            @db.Text
  voiceUrl        String? // survey-media path (audio)
  videoUrl        String? // survey-media path (video)
  mediaKind       SurveyMediaKind? // dominant media kind present, for filtering

  // Optional respondent contact (PDPL: never required).
  respondentName    String?
  respondentContact String? // phone or email, free text

  // Consent + housekeeping.
  consentTestimonial Boolean      @default(false) // use feedback/media in marketing
  consentContact     Boolean      @default(false) // may contact me
  locale             String       @default("ar") // ar | en — locale used to submit
  ipHash             String? // short SHA-256 of IP (abuse triage only)
  status             SurveyStatus @default(NEW) // admin triage
  createdAt          DateTime     @default(now())

  @@index([status, createdAt])
  @@index([respondentType, createdAt])
  @@index([ratingOverall])
}

enum SurveyRespondentType {
  STUDENT
  PARENT
}

enum SurveyImproved {
  YES
  SOME
  NO
}

enum SurveyMediaKind {
  AUDIO
  VIDEO
}

enum SurveyStatus {
  NEW
  REVIEWED
  FEATURED
  ARCHIVED
}
