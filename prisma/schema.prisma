// HAJR A° English Academy — Prisma Schema
// Full schema per spec Section 4.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────── USERS & PROFILES ───────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  nameAr        String?
  phone         String?
  phoneVerified Boolean   @default(false)
  emailVerified Boolean   @default(false)
  role          Role      @default(STUDENT)
  avatar        String?
  timezone      String    @default("Asia/Riyadh")
  preferredLang Lang      @default(AR)
  totpSecret    String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  referredByCode String?
  referredAt     DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacherProfile          TeacherProfile?
  studentProfile          StudentProfile?
  parentProfile           ParentProfile?
  marketerProfile         MarketerProfile?
  messagesSent            Message[]               @relation("MessagesSent")
  messagesReceived        Message[]               @relation("MessagesReceived")
  notifications           Notification[]
  notificationPreferences NotificationPreference?
  auditLogs               AuditLog[]
  agentConversations      AgentConversation[]
  calendarEvents          CalendarEvent[]         @relation("UserCalendarEvents")
  ticketsRequested        Ticket[]                @relation("TicketsRequested")
  ticketsAssigned         Ticket[]                @relation("TicketsAssigned")
  ticketReplies           TicketReply[]
  teacherRatings          TeacherRating[]
  paymentRequests         PaymentRequest[]        @relation("PaymentRequestRequester")
}

model TeacherProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  specializations String[]
  salaryBase      Decimal  @default(0) @db.Decimal(10, 2)
  hourlyRate      Decimal  @default(0) @db.Decimal(10, 2)
  zoomHostEmail   String?
  rating          Decimal? @db.Decimal(3, 2)
  totalStudents   Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Sprint 3 — public profile additions
  introVideoUrl          String?
  languages              String[]
  yearsExp               Int?     @default(0)
  isVerified             Boolean  @default(false)
  publicSlug             String?  @unique
  responseTimeMinutesAvg Int?

  classes         Class[]
  privateLessons  PrivateLesson[]
  blackboardRooms BlackboardRoom[]
  salaryPayments  SalaryPayment[]
  earnings        TeacherEarning[]
  calendarEvents  CalendarEvent[]
  readiness       TeacherReadiness?
  ratings         TeacherRating[]
  meetingAttendees TeacherMeetingAttendee[]
  speakingClubEvents SpeakingClubEvent[]
}

model StudentProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate        DateTime?
  gradeLevel       String?
  englishLevel     EnglishLevel @default(BEGINNER)
  gender           Gender       @default(MALE)
  schoolName       String?
  schoolId         String?
  learningGoals    String?
  activePackage    PackageType?
  packageStartedAt DateTime?
  packageExpiresAt DateTime?
  createdAt        DateTime     @default(now())

  parentLinks           ParentStudentLink[]
  parentInvites         ParentInvite[]
  enrollments           Enrollment[]
  attendances           Attendance[]
  submissions           Submission[]
  invoices              Invoice[]
  subscriptions         Subscription[]
  labAttempts           LabAttempt[]
  skillLevels           SkillLevel[]
  examAttempts          ExamAttempt[]
  privateLessons        PrivateLesson[]
  school                PartnerSchool?         @relation(fields: [schoolId], references: [id])
  blackboardPermissions BlackboardPermission[]
  calendarEvents        CalendarEvent[]
  referrals             MarketerReferral[]
  commissions           Commission[]
  placementAttempts     PlacementAttempt[]
  parentReports         ParentReport[]
  speakingClubRsvps     SpeakingClubRSVP[]
  certificates          Certificate[]
}

model ParentProfile {
  id         String              @id @default(uuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation String?
  inviteCode String              @unique @default(cuid())
  createdAt  DateTime            @default(now())
  childLinks ParentStudentLink[]
}

model ParentStudentLink {
  id        String         @id @default(uuid())
  parentId  String
  parent    ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation  String         @default("parent")
  isPrimary Boolean        @default(false)
  canPay    Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@unique([parentId, studentId])
}

// ─────────────────────── PROGRAMS & CLASSES ───────────────────────
model Program {
  id              String      @id @default(uuid())
  code            String      @unique
  nameEn          String
  nameAr          String
  descriptionEn   String
  descriptionAr   String
  type            ProgramType
  defaultPriceSar Decimal     @db.Decimal(10, 2)
  durationHours   Int?
  active          Boolean     @default(true)

  classes       Class[]
  subscriptions Subscription[]
}

model Class {
  id                   String         @id @default(uuid())
  programId            String
  program              Program        @relation(fields: [programId], references: [id])
  name                 String
  nameAr               String?
  cohortCode           String         @unique
  description          String?
  teacherId            String
  teacher              TeacherProfile @relation(fields: [teacherId], references: [id])
  zoomMeetingId        String?
  zoomPassword         String?
  scheduleDays         DayOfWeek[]
  timeSlot             String
  durationMinutes      Int            @default(60)
  maxStudents          Int            @default(6)
  genderRestriction    Gender?
  allowCrossGenderChat Boolean        @default(false)
  pricePerMonth        Decimal        @default(0) @db.Decimal(10, 2)
  startDate            DateTime
  endDate              DateTime?
  status               ClassStatus    @default(ACTIVE)
  createdAt            DateTime       @default(now())

  enrollments Enrollment[]
  sessions    ClassSession[]
  assignments Assignment[]
  calendarEvents CalendarEvent[]
}

model PrivateLesson {
  id              String         @id @default(uuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id])
  teacherId       String
  teacher         TeacherProfile @relation(fields: [teacherId], references: [id])
  scheduledAt     DateTime
  durationMinutes Int            @default(60)
  zoomMeetingId   String?
  zoomPassword    String?
  status          SessionStatus  @default(SCHEDULED)
  notes           String?
  createdAt       DateTime       @default(now())
}

model Enrollment {
  id         String           @id @default(uuid())
  studentId  String
  student    StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId    String
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())

  @@unique([studentId, classId])
}

model ClassSession {
  id               String        @id @default(uuid())
  classId          String
  class            Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  scheduledDate    DateTime
  zoomMeetingId    String?
  zoomJoinUrl      String?
  zoomPassword     String?
  zoomRecordingUrl String?
  blackboardRoomId String?       @unique
  status           SessionStatus @default(SCHEDULED)
  startedAt        DateTime?
  endedAt          DateTime?
  notes            String?
  createdAt        DateTime      @default(now())

  attendances    Attendance[]
  blackboardRoom BlackboardRoom? @relation(fields: [blackboardRoomId], references: [id])
  earnings       TeacherEarning[]
  lessonSummary  LessonSummary?
}

model Attendance {
  id        String           @id @default(uuid())
  sessionId String
  session   ClassSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    AttendanceStatus @default(PRESENT)
  joinedAt  DateTime?
  leftAt    DateTime?
  markedBy  String?
  notes     String?

  @@unique([sessionId, studentId])
}

// ─────────────────────── BLACKBOARD ───────────────────────
model BlackboardRoom {
  id               String         @id @default(uuid())
  name             String
  teacherId        String
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id])
  snapshotJson     Json?
  tldrawRoomId     String         @unique
  isActive         Boolean        @default(false)
  allowStudentEdit Boolean        @default(false)
  description      String?
  lastEditedBy     String?
  lastEditedAt     DateTime?
  totalEdits       Int            @default(0)
  archivedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  session     ClassSession?
  permissions BlackboardPermission[]
}

model BlackboardPermission {
  id        String         @id @default(uuid())
  roomId    String
  room      BlackboardRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grantedBy String
  grantedAt DateTime       @default(now())
  revokedAt DateTime?

  @@unique([roomId, studentId])
}

// ─────────────────────── ASSIGNMENTS ───────────────────────
model Assignment {
  id          String    @id @default(uuid())
  classId     String
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  titleAr     String?
  description String?
  dueDate     DateTime?
  attachments String[]
  createdAt   DateTime  @default(now())

  submissions Submission[]
}

model Submission {
  id           String         @id @default(uuid())
  assignmentId String
  assignment   Assignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content      String?
  attachments  String[]
  grade        Int?
  feedback     String?
  submittedAt  DateTime       @default(now())
  gradedAt     DateTime?
}

// ─────────────────────── ENGLISH LAB ───────────────────────
model LabExercise {
  id               String       @id @default(uuid())
  type             ExerciseType
  level            CefrLevel
  title            String
  titleAr          String
  description      String?      @db.Text
  descriptionAr    String?      @db.Text
  content          Json
  estimatedMinutes Int          @default(10)
  pointsValue      Int          @default(10)
  tags             String[]
  isPublished      Boolean      @default(false)
  createdBy        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  attempts LabAttempt[]

  @@index([type, level, isPublished])
}

model LabAttempt {
  id            String         @id @default(uuid())
  exerciseId    String
  exercise      LabExercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status        AttemptStatus
  startedAt     DateTime       @default(now())
  completedAt   DateTime?
  timeSpentSec  Int            @default(0)
  submission    Json
  aiEvaluation  Json?
  score         Decimal?       @db.Decimal(5, 2)
  teacherReview String?        @db.Text
  teacherScore  Decimal?       @db.Decimal(5, 2)
  reviewedBy    String?
  reviewedAt    DateTime?

  @@index([studentId, completedAt])
  @@index([exerciseId, score])
}

model SkillLevel {
  id             String         @id @default(uuid())
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill          EnglishSkill
  currentLevel   CefrLevel      @default(A1)
  confidence     Decimal        @default(0) @db.Decimal(5, 2)
  levelHistory   Json           @default("[]")
  totalAttempts  Int            @default(0)
  totalPoints    Int            @default(0)
  lastAssessedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([studentId, skill])
}

// ─────────────────────── STEP TEST BANK ───────────────────────
model TestQuestion {
  id              String       @id @default(uuid())
  testType        TestType
  section         TestSection
  difficulty      Int          @default(3)
  questionText    String       @db.Text
  questionAudio   String?
  passage         String?      @db.Text
  type            QuestionType
  options         Json?
  correctAnswer   Json?
  explanation     String?      @db.Text
  explanationAr   String?      @db.Text
  topic           String?
  tags            String[]
  totalAttempts   Int          @default(0)
  correctAttempts Int          @default(0)
  avgTimeSec      Int?
  isActive        Boolean      @default(true)
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  examQuestions ExamQuestion[]
  answers       ExamAnswer[]

  @@index([testType, section, difficulty, isActive])
}

model TestExam {
  id               String   @id @default(uuid())
  type             ExamType
  testType         TestType
  title            String
  titleAr          String
  description      String?
  totalQuestions   Int
  totalMinutes     Int
  passingScore     Int      @default(60)
  sectionStructure Json
  difficulty       Int      @default(3)
  isPublished      Boolean  @default(true)
  isAdaptive       Boolean  @default(false)
  adaptiveConfig   Json?
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  questions ExamQuestion[]
  attempts  ExamAttempt[]
}

model ExamQuestion {
  id           String       @id @default(uuid())
  examId       String
  exam         TestExam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId   String
  question     TestQuestion @relation(fields: [questionId], references: [id])
  orderIndex   Int
  sectionOrder Int

  @@unique([examId, orderIndex])
  @@index([examId])
}

model ExamAttempt {
  id            String         @id @default(uuid())
  examId        String
  exam          TestExam       @relation(fields: [examId], references: [id])
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status        AttemptStatus
  startedAt     DateTime       @default(now())
  submittedAt   DateTime?
  timeSpentSec  Int            @default(0)
  sectionScores Json           @default("{}")
  totalScore    Decimal?       @db.Decimal(5, 2)
  percentile    Int?
  passed        Boolean?
  writingEval   Json?

  answers ExamAnswer[]

  @@index([studentId, submittedAt])
}

model ExamAnswer {
  id           String       @id @default(uuid())
  attemptId    String
  attempt      ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId   String
  question     TestQuestion @relation(fields: [questionId], references: [id])
  answer       Json
  isCorrect    Boolean?
  pointsEarned Decimal      @default(0) @db.Decimal(5, 2)
  timeSpentSec Int          @default(0)
  aiEval       Json?

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

// ─────────────────────── COMMUNICATION ───────────────────────
model Message {
  id              String        @id @default(uuid())
  threadId        String
  fromUserId      String
  fromUser        User          @relation("MessagesSent", fields: [fromUserId], references: [id])
  toUserId        String?
  toUser          User?         @relation("MessagesReceived", fields: [toUserId], references: [id])
  toRole          Role?
  toClassId       String?
  subject         String?
  body            String        @db.Text
  bodyHtml        String?       @db.Text
  channel         CommChannel
  status          MessageStatus @default(QUEUED)
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  externalId      String?
  errorMessage    String?       @db.Text
  triggerType     TriggerType   @default(MANUAL)
  triggerRefId    String?
  parentMessageId String?
  parentMessage   Message?      @relation("MessageThread", fields: [parentMessageId], references: [id])
  replies         Message[]     @relation("MessageThread")

  // ── Chat attachment (Supabase Storage, bucket `chat-attachments`) ──
  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // mime type
  attachmentSize Int? // bytes

  // ── Admin moderation ──
  flagged       Boolean   @default(false)
  flagReason    String?
  flaggedById   String?
  flaggedAt     DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([threadId])
  @@index([threadId, createdAt])
  @@index([toUserId, status])
  @@index([fromUserId, createdAt])
  @@index([flagged])
}

model EmailTemplate {
  id        String           @id @default(uuid())
  key       String           @unique
  subjectAr String
  subjectEn String
  bodyAr    String           @db.Text
  bodyEn    String           @db.Text
  variables String[]
  category  TemplateCategory
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

/// ContactSubmission — a message from a non-enrolled visitor via the
/// public /contact form or the Hajr public assistant.
model ContactSubmission {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  source    String        @default("contact_form") // contact_form | public_assistant
  repliedBy String?
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
}

// ─────────────────────── FINANCE ───────────────────────

/// Subscription — a student's recurring billing plan for a package.
model Subscription {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  packageType PackageType
  programId   String?
  program     Program?    @relation(fields: [programId], references: [id])

  status SubStatus @default(ACTIVE)

  // Pricing (SAR)
  pricePerMonth Decimal @db.Decimal(10, 2)
  vatRate       Decimal @default(0.15) @db.Decimal(5, 4)
  totalWithVat  Decimal @db.Decimal(10, 2)

  // Billing cycle
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime?
  autoRenew          Boolean   @default(false)

  // Moyasar
  moyasarSubscriptionId String?
  paymentMethodId       String?

  // Promo
  promoCodeId    String?
  promoCode      PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountAmount Decimal    @default(0) @db.Decimal(10, 2)

  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@index([studentId, status])
}

/// Invoice — extended in Phase 8. Legacy month/year/*Sar columns retained
/// for back-compat with Phase 1 tools; Phase 8 fields are nullable additions.
model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  subscriptionId String?
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId       String?

  packageType PackageType?
  classId     String?

  // Legacy period columns (Phase 1) — kept for existing tools.
  month Int
  year  Int

  type InvoiceType @default(SUBSCRIPTION)

  // Legacy status (PaymentStatus) — kept for existing tools/cron.
  status        PaymentStatus @default(PENDING)
  // Phase 8 richer status (DRAFT/PENDING/PAID/OVERDUE/CANCELLED/REFUNDED).
  invoiceStatus InvoiceStatus @default(PENDING)

  // Amounts (SAR). Legacy *Sar columns + Phase 8 aliases (kept in sync).
  subtotalSar Decimal @db.Decimal(10, 2)
  vatSar      Decimal @db.Decimal(10, 2)
  totalSar    Decimal @db.Decimal(10, 2)
  discountSar Decimal @default(0) @db.Decimal(10, 2)

  // ZATCA compliance
  zatcaQrData String? @db.Text
  zatcaUuid   String?
  vatNumber   String?

  // Dates
  issuedAt DateTime  @default(now())
  dueDate  DateTime
  paidAt   DateTime?

  paymentMethod    PaymentMethod?
  moyasarPaymentId String?
  bankRef          String?

  pdfUrl String?

  // Line items: [{ description, descriptionAr, quantity, unitPrice, vatRate, total }]
  lineItems Json?

  notes   String?
  notesAr String?

  payments Payment[]
  commission Commission?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, status])
  @@index([invoiceNumber])
}

/// Payment — a Moyasar (or manual) payment attempt against an invoice.
model Payment {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("SAR")

  // Moyasar
  moyasarPaymentId String?
  moyasarSource    Json?

  status PayStatus @default(INITIATED)

  // Card info (masked — never store full PAN)
  cardBrand String?
  cardLast4 String?

  // Refund tracking
  refundedAmount Decimal   @default(0) @db.Decimal(10, 2)
  refundReason   String?
  refundedAt     DateTime?

  paidAt         DateTime?
  failedAt       DateTime?
  failureMessage String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([moyasarPaymentId])
}

/// PromoCode — discount coupons applicable to subscriptions.
model PromoCode {
  id   String @id @default(uuid())
  code String @unique

  type  PromoType
  value Decimal   @db.Decimal(10, 2)

  // Constraints
  maxUses        Int?
  currentUses    Int  @default(0)
  maxUsesPerUser Int  @default(1)

  // Applicability
  applicablePackages PackageType[]
  applicablePrograms String[]

  // Validity
  startsAt  DateTime
  expiresAt DateTime?
  isActive  Boolean   @default(true)

  description   String?
  descriptionAr String?
  createdBy     String?

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code, isActive])
}

model SalaryPayment {
  id            String         @id @default(uuid())
  payrollNumber String         @unique
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  baseSar       Decimal        @db.Decimal(10, 2)
  bonusSar      Decimal        @default(0) @db.Decimal(10, 2)
  deductionsSar Decimal        @default(0) @db.Decimal(10, 2)
  totalSar      Decimal        @db.Decimal(10, 2)
  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  bankRef       String?
  paidAt        DateTime?
  pdfUrl        String?
  notes         String?
  createdAt     DateTime       @default(now())
}

/// TeacherEarning — per-session earning calculated when a class session
/// completes. PENDING until an admin approves; APPROVED → PAID lifecycle.
model TeacherEarning {
  id             String         @id @default(uuid())
  teacherId      String
  teacher        TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classSessionId String?        @unique
  classSession   ClassSession?  @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  hoursWorked    Decimal        @db.Decimal(5, 2)
  hourlyRate     Decimal        @db.Decimal(10, 2)
  amount         Decimal        @db.Decimal(10, 2)
  status         EarningStatus  @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime       @default(now())

  @@index([teacherId, status])
  @@index([status, createdAt])
}

model PartnerSchool {
  id            String   @id @default(uuid())
  nameEn        String
  nameAr        String
  contactName   String
  contactEmail  String
  contactPhone  String
  city          String
  crNumber      String?
  contractStart DateTime
  contractEnd   DateTime
  monthlyFeeSar Decimal  @db.Decimal(10, 2)
  studentCap    Int
  active        Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())

  students  StudentProfile[]
  contracts SchoolContract[]
}

// ─────────────────────── PHASE 9 — PARENT + SCHOOL ───────────────────────

/// ParentInvite — a one-time code an admin issues so a parent can self-link
/// to a specific student during registration.
model ParentInvite {
  id         String         @id @default(uuid())
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  email      String?
  phone      String?
  inviteCode String         @unique
  status     InviteStatus   @default(PENDING)
  acceptedBy String? // ParentProfile.id once accepted
  expiresAt  DateTime
  createdBy  String?
  createdAt  DateTime       @default(now())

  @@index([inviteCode])
  @@index([studentId, status])
}

/// SchoolContract — a B2B contract between Hajr and a partner school.
model SchoolContract {
  id              String         @id @default(uuid())
  schoolId        String
  school          PartnerSchool  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  programId       String?

  startDate       DateTime
  endDate         DateTime

