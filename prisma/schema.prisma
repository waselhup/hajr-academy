// HAJR A° English Academy — Prisma Schema
// Full schema per spec Section 4.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────── USERS & PROFILES ───────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  nameAr        String?
  phone         String?
  phoneVerified Boolean   @default(false)
  emailVerified Boolean   @default(false)
  role          Role      @default(STUDENT)
  avatar        String?
  timezone      String    @default("Asia/Riyadh")
  preferredLang Lang      @default(AR)
  totpSecret    String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  referredByCode String?
  referredAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherProfile          TeacherProfile?
  studentProfile          StudentProfile?
  parentProfile           ParentProfile?
  marketerProfile         MarketerProfile?
  applicantProfile        ApplicantProfile?
  messagesSent            Message[]                 @relation("MessagesSent")
  messagesReceived        Message[]                 @relation("MessagesReceived")
  notifications           Notification[]
  notificationPreferences NotificationPreference?
  passwordResetTokens     PasswordResetToken[]
  auditLogs               AuditLog[]
  agentConversations      AgentConversation[]
  calendarEvents          CalendarEvent[]           @relation("UserCalendarEvents")
  ticketsRequested        Ticket[]                  @relation("TicketsRequested")
  ticketsAssigned         Ticket[]                  @relation("TicketsAssigned")
  ticketReplies           TicketReply[]
  teacherRatings          TeacherRating[]
  paymentRequests         PaymentRequest[]          @relation("PaymentRequestRequester")
  stickyNotes             StickyNote[]              @relation("StickyNoteOwner")
  targetedRecordings      TargetedRecording[]       @relation("TargetedRecordingUploader")
  targetedRecordingViews  TargetedRecordingViewer[] @relation("TargetedRecordingViewer")
}

model TeacherProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio             String?
  specializations String[]
  // Optional — used by the teacher-audience filter (targeted openings) and later
  // by class-assignment gender matching. null = unspecified (existing teachers).
  gender          Gender?
  salaryBase      Decimal  @default(0) @db.Decimal(10, 2)
  hourlyRate      Decimal  @default(0) @db.Decimal(10, 2)
  // Owner batch 2 — F1: manual USD equivalents shown alongside SAR. Nullable;
  // null = not entered (NOT a live FX rate — admin types these by hand).
  salaryBaseUsd   Decimal? @db.Decimal(10, 2)
  hourlyRateUsd   Decimal? @db.Decimal(10, 2)
  zoomHostEmail   String?
  rating          Decimal? @db.Decimal(3, 2)
  totalStudents   Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Sprint 3 — public profile additions
  introVideoUrl          String?
  languages              String[]
  yearsExp               Int?     @default(0)
  isVerified             Boolean  @default(false)
  publicSlug             String?  @unique
  responseTimeMinutesAvg Int?

  // Owner batch 1 — teaching availability (additive, all nullable).
  ageGroup          String? // age group the teacher serves, e.g. "Kids 6-12", "Teens", "Adults"
  availabilityDays  String[] // days of the week available (SUNDAY..SATURDAY)
  availabilityHours String? // free-text hours, e.g. "4:00 PM - 9:00 PM"

  classes             Class[]
  privateLessons      PrivateLesson[]
  blackboardRooms     BlackboardRoom[]
  salaryPayments      SalaryPayment[]
  earnings            TeacherEarning[]
  calendarEvents      CalendarEvent[]
  readiness           TeacherReadiness?
  ratings             TeacherRating[]
  meetingAttendees    TeacherMeetingAttendee[]
  speakingClubEvents  SpeakingClubEvent[]
  programApplications TeacherApplication[]
  filledOpenings      ProgramOpening[]
  openingAudiences    OpeningAudienceMember[]
  studentEvaluations  StudentEvaluation[]
}

model StudentProfile {
  id               String       @id @default(uuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate        DateTime?
  gradeLevel       String?
  englishLevel     EnglishLevel @default(BEGINNER)
  gender           Gender       @default(MALE)
  schoolName       String?
  schoolId         String?
  learningGoals    String?
  activePackage    PackageType?
  packageStartedAt DateTime?
  packageExpiresAt DateTime?
  createdAt        DateTime     @default(now())

  // Admin-managed enrolment details (Owner batch 1 — additive, all nullable).
  subscriptionDate   DateTime? // when the family subscribed (distinct from package window)
  importantNotes     String? // free-text notes the academy keeps on the student
  studentPhone       String? // the student's own contact number (account phone is on User)
  guardianName       String? // parent/guardian full name
  guardianPhone      String? // parent/guardian contact number
  residenceAddress   String? // home / residence address
  englishTeacherName String? // the student's English teacher (free text)

  parentLinks           ParentStudentLink[]
  parentInvites         ParentInvite[]
  enrollments           Enrollment[]
  attendances           Attendance[]
  submissions           Submission[]
  assignmentTargets     AssignmentTarget[]
  invoices              Invoice[]
  subscriptions         Subscription[]
  labAttempts           LabAttempt[]
  skillLevels           SkillLevel[]
  examAttempts          ExamAttempt[]
  privateLessons        PrivateLesson[]
  school                PartnerSchool?         @relation(fields: [schoolId], references: [id])
  blackboardPermissions BlackboardPermission[]
  calendarEvents        CalendarEvent[]
  referrals             MarketerReferral[]
  commissions           Commission[]
  placementAttempts     PlacementAttempt[]
  parentReports         ParentReport[]
  speakingClubRsvps     SpeakingClubRSVP[]
  certificates          Certificate[]
  evaluations           StudentEvaluation[]
}

model ParentProfile {
  id         String              @id @default(uuid())
  userId     String              @unique
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation String?
  inviteCode String              @unique @default(cuid())
  createdAt  DateTime            @default(now())
  childLinks ParentStudentLink[]
}

model ParentStudentLink {
  id        String         @id @default(uuid())
  parentId  String
  parent    ParentProfile  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation  String         @default("parent")
  isPrimary Boolean        @default(false)
  canPay    Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@unique([parentId, studentId])
}

// ─────────────────────── PROGRAMS & CLASSES ───────────────────────
model Program {
  id              String      @id @default(uuid())
  code            String      @unique
  nameEn          String
  nameAr          String
  descriptionEn   String
  descriptionAr   String
  type            ProgramType
  defaultPriceSar Decimal     @db.Decimal(10, 2)
  durationHours   Int?
  active          Boolean     @default(true)

  classes       Class[]
  subscriptions Subscription[]
  openings      ProgramOpening[]
  applicants    ApplicantProfile[]
}

model Class {
  id                   String         @id @default(uuid())
  programId            String
  program              Program        @relation(fields: [programId], references: [id])
  name                 String
  nameAr               String?
  cohortCode           String         @unique
  description          String?
  teacherId            String
  teacher              TeacherProfile @relation(fields: [teacherId], references: [id])
  zoomMeetingId        String?
  zoomPassword         String?
  scheduleDays         DayOfWeek[]
  timeSlot             String
  durationMinutes      Int            @default(60)
  maxStudents          Int            @default(6)
  genderRestriction    Gender?
  allowCrossGenderChat Boolean        @default(false)
  pricePerMonth        Decimal        @default(0) @db.Decimal(10, 2)
  startDate            DateTime
  endDate              DateTime?
  status               ClassStatus    @default(ACTIVE)
  createdAt            DateTime       @default(now())

  enrollments    Enrollment[]
  sessions       ClassSession[]
  assignments    Assignment[]
  calendarEvents CalendarEvent[]
  resources      ClassResource[]
  evaluations    StudentEvaluation[]
}

// ─────────────────── PROGRAM OPENINGS (apply-to-teach) ───────────────────
// Upstream of class-create + teacher-assignment. When an admin creates a
// Program, a ProgramOpening(OPEN) is created and all active teachers are
// notified to apply. Its own row (not a column on Program) so a program can
// be re-opened for a new term.
model ProgramOpening {
  id              String          @id @default(uuid())
  programId       String
  program         Program         @relation(fields: [programId], references: [id], onDelete: Cascade)
  status          OpeningStatus   @default(OPEN)
  openedBy        String?
  openedAt        DateTime        @default(now())
  filledTeacherId String?
  filledTeacher   TeacherProfile? @relation(fields: [filledTeacherId], references: [id], onDelete: SetNull)
  note            String?
  closedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // ── Targeted audience (who may SEE/apply to this opening) ──
  // Additive: default ALL_INTERNAL preserves the original "notify every active
  // teacher" behaviour. The audience rule is the single source of truth for both
  // the visibility guard and the notify() fan-out.
  audienceType        OpeningAudienceType @default(ALL_INTERNAL)
  // Snapshot of the SELECTED_TEACHERS pick + the filter used to build it, e.g.
  // { teacherIds: [...], filter: { gender, specializations, minRating, ... } }.
  audienceConfig      Json?
  // INTERNAL_THEN_APPLICANTS: false = Phase 1 (internal only); the admin flips it
  // true to start Phase 2 (applicants). The system NEVER auto-opens phase 2.
  applicantsPhaseOpen Boolean             @default(false)
  // Stamped when phase 1 is explicitly closed / phase 2 opened (audit + UI).
  internalClosedAt    DateTime?

  applications    TeacherApplication[]
  audienceMembers OpeningAudienceMember[]

  @@index([programId, status])
  @@index([status, openedAt])
}

// Explicit per-opening audience membership. Used for SELECTED_TEACHERS picks and
// as a fast "already notified?" ledger (notifiedAt) so re-targeting never sends a
// duplicate ping. A member is either a teacher OR an applicant (never both).
model OpeningAudienceMember {
  id          String              @id @default(uuid())
  openingId   String
  opening     ProgramOpening      @relation(fields: [openingId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     TeacherProfile?     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  applicantId String?
  applicant   ApplicantProfile?   @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  source      OpeningMemberSource
  notifiedAt  DateTime?
  createdAt   DateTime            @default(now())

  @@unique([openingId, teacherId])
  @@unique([openingId, applicantId])
  @@index([openingId])
}

// A teacher applies once per opening: short creative survey + optional
// 1-minute voice intro. PDPL: only the audio is stored, no extra PII.
model TeacherApplication {
  id            String            @id @default(uuid())
  openingId     String
  opening       ProgramOpening    @relation(fields: [openingId], references: [id], onDelete: Cascade)
  teacherId     String
  teacher       TeacherProfile    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  status        ApplicationStatus @default(SUBMITTED)
  whyQualified  String            @db.Text
  answersJson   Json?
  voiceIntroUrl String?
  submittedAt   DateTime          @default(now())
  reviewedBy    String?
  reviewedAt    DateTime?
  decisionNote  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([openingId, teacherId])
  @@index([teacherId, status])
  @@index([openingId, status])
}

// ─────────────────── APPLICANT PORTAL (new-teacher applicants) ───────────────────
// An isolated, admin-gated account type for PROSPECTIVE teachers. Fully additive
// and separate from TeacherProfile — an applicant is NOT a teacher and never
// touches the teacher tables until an admin runs "Convert to Teacher". Reuses
// User for auth/email. The applicant's interest in a program is captured as
// `appliedProgramId` (the openings page sets this) so the existing
// TeacherApplication flow stays 100% untouched.
model ApplicantProfile {
  id               String         @id @default(uuid())
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  phone            String?
  appliedProgramId String?
  appliedProgram   Program?       @relation(fields: [appliedProgramId], references: [id], onDelete: SetNull)
  stage            ApplicantStage @default(NEW)
  gender           Gender?
  // Rejected/closed applicants become read-only (no destructive delete).
  isReadOnly       Boolean        @default(false)
  lastActivityAt   DateTime       @default(now())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  featureAccess    ApplicantFeatureAccess[]
  openingAudiences OpeningAudienceMember[]

  @@index([stage, createdAt])
}

// Per-feature gating ABOVE the stage default. Each stage unlocks a default
// bundle; the admin may toggle ANY single feature on/off for max flexibility
// (admin override beats stage defaults). OVERVIEW + OPENINGS + MESSAGING are
// seeded enabled on signup; everything else off until an admin opens it.
model ApplicantFeatureAccess {
  id          String           @id @default(uuid())
  applicantId String
  applicant   ApplicantProfile @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  feature     ApplicantFeature
  enabled     Boolean          @default(false)
  enabledBy   String?
  enabledAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([applicantId, feature])
  @@index([applicantId, enabled])
}

model PrivateLesson {
  id              String         @id @default(uuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id])
  teacherId       String
  teacher         TeacherProfile @relation(fields: [teacherId], references: [id])
  scheduledAt     DateTime
  durationMinutes Int            @default(60)
  zoomMeetingId   String?
  zoomPassword    String?
  status          SessionStatus  @default(SCHEDULED)
  notes           String?
  createdAt       DateTime       @default(now())
}

model Enrollment {
  id         String           @id @default(uuid())
  studentId  String
  student    StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId    String
  class      Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())

  @@unique([studentId, classId])
}

model ClassSession {
  id               String        @id @default(uuid())
  classId          String
  class            Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  scheduledDate    DateTime
  zoomMeetingId    String?
  zoomJoinUrl      String?
  zoomPassword     String?
  zoomRecordingUrl String?
  blackboardRoomId String?       @unique
  status           SessionStatus @default(SCHEDULED)
  startedAt        DateTime?
  endedAt          DateTime?
  notes            String?
  createdAt        DateTime      @default(now())

  attendances    Attendance[]
  blackboardRoom BlackboardRoom?  @relation(fields: [blackboardRoomId], references: [id])
  earnings       TeacherEarning[]
  lessonSummary  LessonSummary?
}

model Attendance {
  id        String           @id @default(uuid())
  sessionId String
  session   ClassSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    AttendanceStatus @default(PRESENT)
  joinedAt  DateTime?
  leftAt    DateTime?
  markedBy  String?
  notes     String?

  @@unique([sessionId, studentId])
}

// ─────────────────────── BLACKBOARD ───────────────────────
model BlackboardRoom {
  id               String         @id @default(uuid())
  name             String
  teacherId        String
  teacher          TeacherProfile @relation(fields: [teacherId], references: [id])
  snapshotJson     Json?
  tldrawRoomId     String         @unique
  isActive         Boolean        @default(false)
  allowStudentEdit Boolean        @default(false)
  description      String?
  lastEditedBy     String?
  lastEditedAt     DateTime?
  totalEdits       Int            @default(0)
  archivedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  session     ClassSession?
  permissions BlackboardPermission[]
}

model BlackboardPermission {
  id        String         @id @default(uuid())
  roomId    String
  room      BlackboardRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grantedBy String
  grantedAt DateTime       @default(now())
  revokedAt DateTime?

  @@unique([roomId, studentId])
}

// ─────────────────────── ASSIGNMENTS ───────────────────────
// Kind of a rich attachment, shared by teacher material and student
// submissions. Also used for `Assignment.allowedResponseTypes` to gate
// which response kinds a student may submit (TEXT is always allowed in code
// as a fallback even when the list is empty).
enum AttachmentKind {
  VIDEO
  AUDIO
  TEXT
  FILE
  // External link (YouTube, Drive, website). For LINK the `url` column holds the
  // external http(s) URL itself (not a storage path). Batch 4C — additive.
  LINK
}

// Who an assignment is for. ALL_CLASS (default, backward-compatible) = every
// ACTIVE-enrolled student in the class. SELECTED = only the students listed in
// AssignmentTarget. Visibility/eligibility is always derived from this via the
// `isAssignmentVisibleToStudent` helper — never trusted from the client.
enum AssignmentAudience {
  ALL_CLASS
  SELECTED
}

// Lightweight "folder" for a teacher's private class materials. A flat set of
// categories (not a nested tree) used as filter chips on the Resources tab.
enum ClassResourceCategory {
  LESSON_PLAN
  EXERCISE
  SLIDES
  OTHER
}

model Assignment {
  id                   String             @id @default(uuid())
  classId              String
  class                Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  title                String
  titleAr              String?
  description          String?
  dueDate              DateTime?
  attachments          String[]
  // Response kinds the student is allowed to submit. Empty = text-only.
  allowedResponseTypes AttachmentKind[]   @default([])
  // Opt-in targeting. ALL_CLASS keeps today's whole-class behavior; SELECTED
  // restricts the assignment to the students in `targets`.
  audience             AssignmentAudience @default(ALL_CLASS)
  createdAt            DateTime           @default(now())

  submissions    Submission[]
  attachmentList AssignmentAttachment[]
  targets        AssignmentTarget[]
}

// Join row: one per student an assignment is explicitly targeted to. Only
// populated when Assignment.audience = SELECTED. The selected set must always
// be a subset of the class's ACTIVE enrollments (validated server-side).
model AssignmentTarget {
  id           String         @id @default(uuid())
  assignmentId String
  assignment   Assignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model Submission {
  id           String         @id @default(uuid())
  assignmentId String
  assignment   Assignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content      String?
  attachments  String[]
  grade        Int?
  feedback     String?
  submittedAt  DateTime       @default(now())
  gradedAt     DateTime?

  attachmentList SubmissionAttachment[]
}

// Generic rich attachment on the teacher's assignment material.
// Stored in the private `assignment-media` bucket; `url` holds the storage
// path (signed on demand by the access-controlled fetch endpoint).
model AssignmentAttachment {
  id           String         @id @default(uuid())
  assignmentId String
  assignment   Assignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  kind         AttachmentKind
  url          String
  fileName     String
  mimeType     String
  sizeBytes    Int
  durationSec  Int?
  createdAt    DateTime       @default(now())

  @@index([assignmentId])
}

// Generic rich attachment on a student's submission. Same shape as the
// teacher side; one submission → many attachments.
model SubmissionAttachment {
  id           String         @id @default(uuid())
  submissionId String
  submission   Submission     @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  kind         AttachmentKind
  url          String
  fileName     String
  mimeType     String
  sizeBytes    Int
  durationSec  Int?
  createdAt    DateTime       @default(now())

  @@index([submissionId])
}

// A teacher's private teaching material kept WITH a class. Because it hangs off
// the class (not a term/cohort), whenever the same — or a future — assigned
// teacher reopens this class they find every prior resource ready to reuse.
// `kind` reuses AttachmentKind (VIDEO/AUDIO/FILE; documents/images/pdf/slides
// are all FILE, refined for display by mimeType). `category` is the chip-level
// folder. The uploader is recorded as a plain user id (mirrors `createdBy`).
// Access is decided server-side: only a teacher assigned to the class, or an
// admin, may list or fetch; only the uploader (or an admin) may rename/delete.
model ClassResource {
  id               String                @id @default(uuid())
  classId          String
  class            Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  uploadedByUserId String
  kind             AttachmentKind
  category         ClassResourceCategory @default(OTHER)
  title            String
  fileName         String
  mimeType         String
  sizeBytes        Int
  url              String
  createdAt        DateTime              @default(now())

  @@index([classId])
  @@index([classId, category])
}

// ─────────────────────── ENGLISH LAB ───────────────────────
model LabExercise {
  id               String       @id @default(uuid())
  type             ExerciseType
  level            CefrLevel
  title            String
  titleAr          String
  description      String?      @db.Text
  descriptionAr    String?      @db.Text
  content          Json
  estimatedMinutes Int          @default(10)
  pointsValue      Int          @default(10)
  tags             String[]
  isPublished      Boolean      @default(false)
  createdBy        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  attempts LabAttempt[]

  @@index([type, level, isPublished])
}

model LabAttempt {
  id            String         @id @default(uuid())
  exerciseId    String
  exercise      LabExercise    @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status        AttemptStatus
  startedAt     DateTime       @default(now())
  completedAt   DateTime?
  timeSpentSec  Int            @default(0)
  submission    Json
  aiEvaluation  Json?
  score         Decimal?       @db.Decimal(5, 2)
  teacherReview String?        @db.Text
  teacherScore  Decimal?       @db.Decimal(5, 2)
  reviewedBy    String?
  reviewedAt    DateTime?

  @@index([studentId, completedAt])
  @@index([exerciseId, score])
}

model SkillLevel {
  id             String         @id @default(uuid())
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill          EnglishSkill
  currentLevel   CefrLevel      @default(A1)
  confidence     Decimal        @default(0) @db.Decimal(5, 2)
  levelHistory   Json           @default("[]")
  totalAttempts  Int            @default(0)
  totalPoints    Int            @default(0)
  lastAssessedAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([studentId, skill])
}

// ─────────────────────── STEP TEST BANK ───────────────────────
model TestQuestion {
  id              String       @id @default(uuid())
  testType        TestType
  section         TestSection
  difficulty      Int          @default(3)
  questionText    String       @db.Text
  questionAudio   String?
  passage         String?      @db.Text
  type            QuestionType
  options         Json?
  correctAnswer   Json?
  explanation     String?      @db.Text
  explanationAr   String?      @db.Text
  topic           String?
  tags            String[]
  totalAttempts   Int          @default(0)
  correctAttempts Int          @default(0)
  avgTimeSec      Int?
  isActive        Boolean      @default(true)
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  examQuestions ExamQuestion[]
  answers       ExamAnswer[]

  @@index([testType, section, difficulty, isActive])
}

model TestExam {
  id               String   @id @default(uuid())
  type             ExamType
  testType         TestType
  title            String
  titleAr          String
  description      String?
  totalQuestions   Int
  totalMinutes     Int
  passingScore     Int      @default(60)
  sectionStructure Json
  difficulty       Int      @default(3)
  isPublished      Boolean  @default(true)
  isAdaptive       Boolean  @default(false)
  adaptiveConfig   Json?
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  questions ExamQuestion[]
  attempts  ExamAttempt[]
}

model ExamQuestion {
  id           String       @id @default(uuid())
  examId       String
  exam         TestExam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId   String
  question     TestQuestion @relation(fields: [questionId], references: [id])
  orderIndex   Int
  sectionOrder Int

  @@unique([examId, orderIndex])
  @@index([examId])
}

model ExamAttempt {
  id            String         @id @default(uuid())
  examId        String
  exam          TestExam       @relation(fields: [examId], references: [id])
  studentId     String
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status        AttemptStatus
  startedAt     DateTime       @default(now())
  submittedAt   DateTime?
  timeSpentSec  Int            @default(0)
  sectionScores Json           @default("{}")
  totalScore    Decimal?       @db.Decimal(5, 2)
  percentile    Int?
  passed        Boolean?
  writingEval   Json?

  answers ExamAnswer[]

  @@index([studentId, submittedAt])
}

model ExamAnswer {
  id           String       @id @default(uuid())
  attemptId    String
  attempt      ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId   String
  question     TestQuestion @relation(fields: [questionId], references: [id])
  answer       Json
  isCorrect    Boolean?
  pointsEarned Decimal      @default(0) @db.Decimal(5, 2)
  timeSpentSec Int          @default(0)
  aiEval       Json?

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

// ─────────────────────── COMMUNICATION ───────────────────────
model Message {
  id              String        @id @default(uuid())
  threadId        String
  fromUserId      String
  fromUser        User          @relation("MessagesSent", fields: [fromUserId], references: [id])
  toUserId        String?
  toUser          User?         @relation("MessagesReceived", fields: [toUserId], references: [id])
  toRole          Role?
  toClassId       String?
  subject         String?
  body            String        @db.Text
  bodyHtml        String?       @db.Text
  channel         CommChannel
  status          MessageStatus @default(QUEUED)
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  externalId      String?
  errorMessage    String?       @db.Text
  triggerType     TriggerType   @default(MANUAL)
  triggerRefId    String?
  parentMessageId String?
  parentMessage   Message?      @relation("MessageThread", fields: [parentMessageId], references: [id])
  replies         Message[]     @relation("MessageThread")

  // ── Chat attachment (Supabase Storage, bucket `chat-attachments`) ──
  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // mime type
  attachmentSize Int? // bytes

  // ── Admin moderation ──
  flagged     Boolean   @default(false)
  flagReason  String?
  flaggedById String?
  flaggedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
  @@index([threadId, createdAt])
  @@index([toUserId, status])
  @@index([fromUserId, createdAt])
  @@index([flagged])
}

model EmailTemplate {
  id        String           @id @default(uuid())
  key       String           @unique
  subjectAr String
  subjectEn String
  bodyAr    String           @db.Text
  bodyEn    String           @db.Text
  variables String[]
  category  TemplateCategory
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

/// ContactSubmission — a message from a non-enrolled visitor via the
/// public /contact form or the Hajr public assistant.
model ContactSubmission {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  source    String        @default("contact_form") // contact_form | public_assistant
  repliedBy String?
  repliedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
}

// ─────────────────────── FINANCE ───────────────────────

/// Subscription — a student's recurring billing plan for a package.
model Subscription {
  id        String         @id @default(uuid())
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  packageType PackageType
  programId   String?
  program     Program?    @relation(fields: [programId], references: [id])

  status SubStatus @default(ACTIVE)

  // Pricing (SAR)
  pricePerMonth Decimal @db.Decimal(10, 2)
  vatRate       Decimal @default(0.15) @db.Decimal(5, 4)
  totalWithVat  Decimal @db.Decimal(10, 2)

  // Billing cycle
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime?
  autoRenew          Boolean   @default(false)

  // Moyasar
  moyasarSubscriptionId String?
  paymentMethodId       String?

  // Promo
  promoCodeId    String?
  promoCode      PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountAmount Decimal    @default(0) @db.Decimal(10, 2)

  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@index([studentId, status])
}

/// Invoice — extended in Phase 8. Legacy month/year/*Sar columns retained
/// for back-compat with Phase 1 tools; Phase 8 fields are nullable additions.
model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  subscriptionId String?
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  schoolId       String?

  packageType PackageType?
  classId     String?

  // Legacy period columns (Phase 1) — kept for existing tools.
  month Int
  year  Int

  type InvoiceType @default(SUBSCRIPTION)

  // Legacy status (PaymentStatus) — kept for existing tools/cron.
  status        PaymentStatus @default(PENDING)
  // Phase 8 richer status (DRAFT/PENDING/PAID/OVERDUE/CANCELLED/REFUNDED).
  invoiceStatus InvoiceStatus @default(PENDING)

  // Amounts (SAR). Legacy *Sar columns + Phase 8 aliases (kept in sync).
  subtotalSar Decimal @db.Decimal(10, 2)
  vatSar      Decimal @db.Decimal(10, 2)
  totalSar    Decimal @db.Decimal(10, 2)
  discountSar Decimal @default(0) @db.Decimal(10, 2)

  // ZATCA compliance
  zatcaQrData String? @db.Text
  zatcaUuid   String?
  vatNumber   String?

  // Dates
  issuedAt DateTime  @default(now())
  dueDate  DateTime
  paidAt   DateTime?

  paymentMethod    PaymentMethod?
  moyasarPaymentId String?
  bankRef          String?

  pdfUrl String?

  // Line items: [{ description, descriptionAr, quantity, unitPrice, vatRate, total }]
  lineItems Json?

  notes   String?
  notesAr String?

  payments   Payment[]
  commission Commission?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, status])
  @@index([invoiceNumber])
}

/// Payment — a Moyasar (or manual) payment attempt against an invoice.
model Payment {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("SAR")

  // Moyasar
  moyasarPaymentId String?
  moyasarSource    Json?

  status PayStatus @default(INITIATED)

  // Card info (masked — never store full PAN)
  cardBrand String?
  cardLast4 String?

  // Refund tracking
  refundedAmount Decimal   @default(0) @db.Decimal(10, 2)
  refundReason   String?
  refundedAt     DateTime?

  paidAt         DateTime?
  failedAt       DateTime?
  failureMessage String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([moyasarPaymentId])
}

/// PromoCode — discount coupons applicable to subscriptions.
model PromoCode {
  id   String @id @default(uuid())
  code String @unique

  type  PromoType
  value Decimal   @db.Decimal(10, 2)

  // Constraints
  maxUses        Int?
  currentUses    Int  @default(0)
  maxUsesPerUser Int  @default(1)

  // Applicability
  applicablePackages PackageType[]
  applicablePrograms String[]

  // Validity
  startsAt  DateTime
  expiresAt DateTime?
  isActive  Boolean   @default(true)

  description   String?
  descriptionAr String?
  createdBy     String?

  // Success Partner (organization) this promo belongs to (batch 4B — additive,
  // optional). Lets the admin tie a promo to a charity / school / marketer.
  partnerSchoolId String?
  partnerSchool   PartnerSchool? @relation(fields: [partnerSchoolId], references: [id])

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code, isActive])
  @@index([partnerSchoolId])
}

model SalaryPayment {
  id            String         @id @default(uuid())
  payrollNumber String         @unique
  teacherId     String
  teacher       TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  month         Int
  year          Int
  baseSar       Decimal        @db.Decimal(10, 2)
  bonusSar      Decimal        @default(0) @db.Decimal(10, 2)
  deductionsSar Decimal        @default(0) @db.Decimal(10, 2)
  totalSar      Decimal        @db.Decimal(10, 2)
  status        PaymentStatus  @default(PENDING)
  paymentMethod PaymentMethod?
  bankRef       String?
  paidAt        DateTime?
  pdfUrl        String?
  notes         String?
  createdAt     DateTime       @default(now())
}

/// TeacherEarning — per-session earning calculated when a class session
/// completes. PENDING until an admin approves; APPROVED → PAID lifecycle.
model TeacherEarning {
  id             String         @id @default(uuid())
  teacherId      String
  teacher        TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classSessionId String?        @unique
  classSession   ClassSession?  @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  hoursWorked    Decimal        @db.Decimal(5, 2)
  hourlyRate     Decimal        @db.Decimal(10, 2)
  amount         Decimal        @db.Decimal(10, 2)
  status         EarningStatus  @default(PENDING)
  approvedBy     String?
  approvedAt     DateTime?
  paidAt         DateTime?
  notes          String?
  createdAt      DateTime       @default(now())

  @@index([teacherId, status])
  @@index([status, createdAt])
}

/// PartnerType — the kind of "Success Partner" (شريك النجاح). Owner batch 4B:
/// the "School Partner" concept is reframed as a broader "Success Partner"
/// covering charities, schools, and individual marketers. Additive + nullable;
/// the underlying model/table names stay (display-only rename).
enum PartnerType {
  CHARITY
  SCHOOL
  INDIVIDUAL
}

model PartnerSchool {
  id            String   @id @default(uuid())
  nameEn        String
  nameAr        String
  contactName   String
  contactEmail  String
  contactPhone  String
  city          String
  crNumber      String?
  contractStart DateTime
  contractEnd   DateTime
  monthlyFeeSar Decimal  @db.Decimal(10, 2)
  studentCap    Int
  active        Boolean  @default(true)
  notes         String?
  // Success Partner kind (batch 4B — additive). Existing rows are schools.
  partnerType   PartnerType? @default(SCHOOL)
  createdAt     DateTime @default(now())

  students   StudentProfile[]
  contracts  SchoolContract[]
  promoCodes PromoCode[]
}

// ─────────────────────── PHASE 9 — PARENT + SCHOOL ───────────────────────

/// ParentInvite — a one-time code an admin issues so a parent can self-link
/// to a specific student during registration.
model ParentInvite {
  id         String         @id @default(uuid())
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  email      String?
  phone      String?
  inviteCode String         @unique
  status     InviteStatus   @default(PENDING)
  acceptedBy String? // ParentProfile.id once accepted
  expiresAt  DateTime
  createdBy  String?
  createdAt  DateTime       @default(now())

  @@index([inviteCode])
  @@index([studentId, status])
}

/// SchoolContract — a B2B contract between Hajr and a partner school.
model SchoolContract {
  id        String        @id @default(uuid())
  schoolId  String
  school    PartnerSchool @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  programId String?

  startDate DateTime
  endDate   DateTime

  totalStudents   Int
  pricePerStudent Decimal @db.Decimal(10, 2)
  totalAmount     Decimal @db.Decimal(10, 2)
  vatAmount       Decimal @db.Decimal(10, 2)

  status   ContractStatus @default(DRAFT)
  signedAt DateTime?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status])
}

