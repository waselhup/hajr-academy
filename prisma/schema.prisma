  approvedAt      DateTime?
  paidBy          String?
  paidAt          DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime         @default(now())

  @@index([marketerId, status])
  @@index([status, createdAt])
}

model PlacementTest {
  id            String             @id @default(uuid())
