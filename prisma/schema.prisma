  updatedAt       DateTime             @updatedAt

  @@index([requesterId, status])
  @@index([status, createdAt])
}

// ─────────────────────── SPRINT 5 — AI + BRAND ───────────────────────
model LessonSummary {
  id               String       @id @default(uuid())
  sessionId        String       @unique
  session          ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transcript       String?      @db.Text
  summaryEn        String       @db.Text
  summaryAr        String       @db.Text
  keyVocab         Json?
  grammarPoints    Json?
  homework         String?      @db.Text
  homeworkAr       String?      @db.Text
  teacherActions   String?      @db.Text
  teacherActionsAr String?      @db.Text
  confidence       Decimal?     @db.Decimal(3, 2)
  generatedById    String?
  generatedAt      DateTime     @default(now())

  @@index([sessionId])
}

model BrandKitAsset {
  id            String   @id @default(uuid())
  name          String
  nameAr        String
  type          String
  category      String
  url           String
  downloadUrl   String
  description   String?  @db.Text
  descriptionAr String?  @db.Text
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@index([category, sortOrder])
}

// ─────────────────────── SPRINT 7A — LIBRARY ───────────────────────

enum LibraryItemType {
  ARTICLE
  VIDEO
  EXERCISE
  AUDIO
  PDF
}

enum LibrarySkillLevel {
  A1
  A2
  B1
  B2
  C1
  C2
  ALL
}

enum LibraryAgeTier {
  TIER_1_3
  TIER_4_6
  MIDDLE
  HIGH
  ALL
}

enum LibraryProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

model LibraryItem {
  id               String                @id @default(uuid())
  title            String
  titleAr          String
  description      String?               @db.Text
  descriptionAr    String?               @db.Text
  type             LibraryItemType
  skillLevel       LibrarySkillLevel     @default(ALL)
  targetAgeTier    LibraryAgeTier        @default(ALL)
  contentUrl       String?
  contentHtml      String?               @db.Text
  durationMinutes  Int                   @default(5)
  thumbnailUrl     String?
  authorId         String?
  isPublished      Boolean               @default(false)
  publishedAt      DateTime?
  viewCount        Int                   @default(0)
  exerciseData     Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tags             LibraryItemTag[]
  progress         LibraryProgress[]
  exerciseAttempts LibraryExerciseAttempt[]

  @@index([type, isPublished])
  @@index([targetAgeTier, skillLevel])
  @@index([authorId])
}

model LibraryItemTag {
  id     String      @id @default(uuid())
  itemId String
  item   LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    String

  @@unique([itemId, tag])
  @@index([tag])
}

model LibraryProgress {
  id            String                @id @default(uuid())
  studentId     String
  libraryItemId String
  libraryItem   LibraryItem           @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  status        LibraryProgressStatus @default(NOT_STARTED)
  progressPct   Int                   @default(0)
  timeSpentSec  Int                   @default(0)
  lastAccessAt  DateTime              @default(now())
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([studentId, libraryItemId])
  @@index([studentId, status])
}

model LibraryExerciseAttempt {
  id            String      @id @default(uuid())
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  studentId     String
  score         Int         @default(0)
  answersJson   Json
  completedAt   DateTime    @default(now())

  @@index([studentId, completedAt])
  @@index([libraryItemId])
}

// ─────────────────────── SPRINT 7A — TECH CHECK ───────────────────────

model TechCheck {
  id                 String   @id @default(uuid())
  teacherId          String
  sessionId          String?
  downloadMbps       Decimal  @db.Decimal(6, 2)
  uploadMbps         Decimal  @db.Decimal(6, 2)
  latencyMs          Int
  audioPeakDb        Decimal  @db.Decimal(5, 2)
  cameraOk           Boolean
  micOk              Boolean
  score              Int
  passed             Boolean
  failureReasons     String[]
  createdAt          DateTime @default(now())

  @@index([teacherId, createdAt])
  @@index([passed, createdAt])
}

// ─────────────────────── SPRINT 7A — ACTIVITY ANALYTICS ───────────────────────

model UserSession {
  id             String     @id @default(uuid())
  userId         String
  role           Role
  startedAt      DateTime   @default(now())
  endedAt        DateTime?
  ipHash         String?
  userAgentHash  String?
  durationSec    Int        @default(0)

  pageVisits     PageVisit[]

  @@index([userId, startedAt])
  @@index([startedAt])
  @@index([endedAt])
}

model PageVisit {
  id           String       @id @default(uuid())
  userId       String
  sessionId    String?
  session      UserSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  route        String
  enteredAt    DateTime     @default(now())
  leftAt       DateTime?
  durationSec  Int          @default(0)

  @@index([userId, enteredAt])
  @@index([route, enteredAt])
  @@index([sessionId])
}

// ─────────────────────── SPRINT 7B — GAMIFICATION ───────────────────────

enum AgeTier {
  TIER_1_3
  TIER_4_6
  MIDDLE
  HIGH
}

model StudentGamification {
  id              String   @id @default(uuid())
  studentId       String   @unique
  xp              Int      @default(0)
  level           Int      @default(1)
  streakDays      Int      @default(0)
  lastActiveDate  DateTime @default(now())
  ageTier         AgeTier  @default(MIDDLE)
  avatarFrame     String   @default("none")
  title           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  achievements    StudentAchievement[]

  @@index([xp])
  @@index([level])
}

model Achievement {
  id            String  @id @default(uuid())
  key           String  @unique
  nameAr        String
  nameEn        String
  descriptionAr String  @db.Text
  descriptionEn String  @db.Text
  iconKey       String
  xpReward      Int     @default(10)
  ageTier       AgeTier?
  category      String
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())

  earned        StudentAchievement[]
}

model StudentAchievement {
  id             String              @id @default(uuid())
  studentId      String
  gamification   StudentGamification @relation(fields: [studentId], references: [studentId], onDelete: Cascade)
  achievementId  String
  achievement    Achievement         @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt       DateTime            @default(now())
  isClaimed      Boolean             @default(false)
  claimedAt      DateTime?

  @@unique([studentId, achievementId])
  @@index([studentId, earnedAt])
}

// Public landing-page purchase orders awaiting admin provisioning.
// Customer submits (student name + phone required, email optional), pays
// (mock now, Moyasar-ready), then admin creates the student account and
// assigns class/program/teacher. Mirrors the TrialRequest lead-capture pattern.
model PurchaseOrder {
  id                   String             @id @default(uuid())
  // Customer-provided at checkout
  studentName          String
  phone                String
  email                String?
  packageType          PackageType
  notes                String?
  // Payment (mock now, Moyasar-ready)
  amountSar            Decimal            @db.Decimal(10, 2)
  paymentStatus        OrderPaymentStatus @default(PENDING)
  moyasarPaymentId     String?
  paidAt               DateTime?
  // Admin provisioning workflow
  status               OrderStatus        @default(NEW)
  provisionedStudentId String?
  assignedClassId      String?
  handledBy            String?
  handledAt            DateTime?
  source               String             @default("landing_checkout")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status, createdAt])
  @@index([paymentStatus])
}
